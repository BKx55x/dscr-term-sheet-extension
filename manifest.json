{
  "manifest_version": 3,
  "name": "DSCR Loan Term Sheet Editor",
  "version": "1.0.0",
  "description": "Edit, auto-calculate, and parse DSCR rental loan term sheets. Click the icon to open the editor.",
  "action": {
    "default_title": "Open DSCR Term Sheet Editor",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
